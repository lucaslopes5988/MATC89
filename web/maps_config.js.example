// Copie este arquivo como maps_config.js e substitua pela sua chave.
// O arquivo maps_config.js é ignorado pelo git.
(function loadGoogleMaps() {
  var script = document.createElement('script');
  script.src = 'https://maps.googleapis.com/maps/api/js?key=YOUR_MAPS_API_KEY&loading=async&v=weekly&libraries=places';
  document.head.appendChild(script);
})();
